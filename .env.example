# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/lifegraphai
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=super_secret_jwt_key_change_in_prod
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_prod
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Encryption (Needs to be exactly 64 hex chars for AES-256 HKDF if we derive from it, or 64 hex / 32 bytes for raw key)
# Example: 64 hex chars = 32 bytes
ENCRYPTION_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Storage (MinIO local dev config)
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=admin
R2_SECRET_ACCESS_KEY=password
R2_BUCKET_NAME=lifegraphai
S3_ENDPOINT_URL=http://localhost:9000

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# AI
OPENAI_API_KEY=your_openai_api_key
EMBEDDING_MODEL=BAAI/bge-m3
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
